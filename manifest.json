{
  "manifest_version": 3,
  "name": "Telegram Session Extractor",
  "version": "2.1.0",
  "description": "Extract Telegram Mini App session data: initData, cookies, iframe data, user info — multi-project support",
  "permissions": [
    "activeTab",
    "storage",
    "cookies",
    "scripting",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
